# Banco de Dados
DB_URL=jdbc:postgresql://localhost:5432/futspringdb
DB_USERNAME=futspringuser
DB_PASSWORD=your_secure_password_here

# JWT — gere um segredo forte: openssl rand -base64 64
JWT_SECRET=your_very_long_and_secure_jwt_secret_here
JWT_EXPIRATION_MS=604800000

# Hibernate DDL — use 'update' em dev, 'validate' em prod
DDL_AUTO=update

# Origens permitidas para WebSocket (separadas por vírgula se mais de uma)
ALLOWED_ORIGINS=https://futspring.luisgosampaio.com

# Spring Profile — use 'prod' em produção para desativar o DataInitializer
SPRING_PROFILES_ACTIVE=prod
